showCorrectiveLabels = input.bool(true, "Show Corrective (A-B-C)", group=waveGroup)
showSubWaves = input.bool(false, "Show Sub-Waves (i-v)", group=waveGroup)
showWaveLines = input.bool(true, "Connect Waves with Lines", group=waveGroup)
showWaveZones = input.bool(false, "Show Wave Zones (Boxes)", group=waveGroup)

// === Pattern Detection ===
patternGroup = "Pattern Detection"
detectImpulse = input.bool(true, "Detect Impulse Waves", group=patternGroup)
detectZigzag = input.bool(true, "Detect Zigzag Corrections", group=patternGroup)
detectFlat = input.bool(true, "Detect Flat Corrections", group=patternGroup)
detectTriangle = input.bool(true, "Detect Triangles", group=patternGroup)
